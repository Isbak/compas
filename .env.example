# Compas configuration — copy to .env and adjust. Compas is a pure client of
# the Navigate REST API; it has no database or API of its own.

# --- Navigate API (the only backend) ------------------------------------
# Base URL of Navigate's REST API, including the /api prefix.
# Start it from your Navigate checkout with:  catalog api
COMPAS_NAVIGATE_API_URL=http://127.0.0.1:8000/api
# Optional bearer token (only if Navigate has API-key auth enabled).
COMPAS_NAVIGATE_API_KEY=
COMPAS_NAVIGATE_TIMEOUT=30
COMPAS_NAVIGATE_ASK_TIMEOUT=120

# --- Display / performance ----------------------------------------------
COMPAS_PAGE_SIZE=50
COMPAS_MAX_PAGE_SIZE=500
COMPAS_GRAPH_NODE_LIMIT=250
COMPAS_ASK_DEPTH=2
