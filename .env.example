# Compas configuration — copy to .env and adjust. All settings are optional;
# Compas is local-first and runs with sensible defaults (seeding a demo
# catalog on first run).

# --- Catalog -------------------------------------------------------------
# Path to Navigate's SQLite catalog (its system of record).
COMPAS_DATABASE_PATH=./data/catalog.sqlite
# Open the catalog read-only (governance actions disabled) — default false.
COMPAS_READ_ONLY=false
# Seed a synthetic demo catalog when the database is missing — default true.
COMPAS_DEMO_MODE=true

# --- Pagination / performance -------------------------------------------
COMPAS_PAGE_SIZE=50
COMPAS_GRAPH_NODE_LIMIT=250

# --- Fuseki (SPARQL) — disabled by default (local-first) -----------------
COMPAS_FUSEKI_ENABLED=false
COMPAS_FUSEKI_ENDPOINT=http://localhost:3030/navigate

# --- GraphRAG ------------------------------------------------------------
# When disabled, Compas answers from the local graph (no network calls).
COMPAS_GRAPHRAG_ENABLED=false
COMPAS_GRAPHRAG_ENDPOINT=

# --- LLM provider (surfaced on the Settings page) ------------------------
COMPAS_LLM_PROVIDER=ollama
COMPAS_OLLAMA_ENDPOINT=http://localhost:11434
COMPAS_OLLAMA_MODEL=llama3.1
COMPAS_OPENAI_MODEL=gpt-4o-mini

# --- Governance ----------------------------------------------------------
COMPAS_REVIEW_INTERVAL_DAYS=90
COMPAS_STALE_AFTER_DAYS=180
